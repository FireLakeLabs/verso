{
  "name": "@verso/frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --strictPort",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "format:check": "prettier --check .",
    "lint": "oxlint src tests --deny-warnings",
    "preview": "vite preview --host 127.0.0.1 --strictPort",
    "test": "tsx --test src/**/*.test.ts",
    "test:smoke": "tsx tests/verso-shell-smoke.ts",
    "test:visual": "tsx tests/verso-visual-parity.ts",
    "test:visual:update": "tsx tests/update-visual-parity-baselines.ts",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "clsx": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.5.0",
    "oxlint": "latest",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "tsx": "latest",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
